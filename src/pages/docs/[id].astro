---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	return docs.map((entry) => ({
		params: { id: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<SiteLayout title={entry.data.title} description={entry.data.description}>
	<div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
		<nav class="text-sm text-slate-500">
			<a href="/docs" class="text-cyan-500/90 no-underline hover:text-cyan-400">Documentation</a>
			<span class="mx-2 text-slate-600">/</span>
			<span class="text-slate-400">{entry.data.title}</span>
		</nav>
		<h1 class="mt-4 text-3xl font-bold tracking-tight text-white sm:text-4xl">{entry.data.title}</h1>
		<p class="mt-3 max-w-2xl text-lg text-slate-400">{entry.data.description}</p>
		<article
			class="prose prose-invert prose-slate mt-10 max-w-3xl prose-headings:scroll-mt-24 prose-headings:font-semibold prose-headings:text-white prose-a:text-cyan-400 prose-a:no-underline hover:prose-a:underline prose-strong:text-slate-200 prose-code:rounded prose-code:bg-slate-800/80 prose-code:px-1 prose-code:py-0.5 prose-code:text-cyan-200/90 prose-code:before:content-none prose-code:after:content-none prose-table:border prose-table:border-slate-700 prose-th:border prose-th:border-slate-700 prose-th:bg-slate-900 prose-th:px-3 prose-th:py-2 prose-td:border prose-td:border-slate-800 prose-td:px-3 prose-td:py-2"
		>
			<Content />
		</article>
		<div class="mt-12 border-t border-slate-800 pt-8">
			<a href="/docs" class="text-sm font-medium text-cyan-400 no-underline hover:text-cyan-300"
				>← All documentation</a
			>
		</div>
	</div>
</SiteLayout>
